<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Room database — it's rebuilt from MediaStore on restore -->
        <exclude
            domain="database"
            path="wavora_database" />
        <!-- Exclude DataStore — user will reconfigure preferences -->
        <exclude
            domain="file"
            path="datastore/" />
    </cloud-backup>
</data-extraction-rules>
