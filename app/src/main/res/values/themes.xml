<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base application theme.
        Compose overrides the visual theme entirely via WavoraTheme.
        This XML theme only needs to satisfy WindowManager before Compose takes over.
    -->
    <style name="Theme.Wavora" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Compose sets the actual colors via SideEffect in Theme.kt -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!--
        Splash screen theme (applied only to MainActivity before setContent is called).
        Uses the core-splashscreen library which handles the animated transition.
    -->
    <style name="Theme.Wavora.Splash" parent="Theme.SplashScreen">
        <!-- Splash screen icon — update with real WAVORA icon in Phase 10 -->
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="postSplashScreenTheme">@style/Theme.Wavora</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
    </style>
</resources>
