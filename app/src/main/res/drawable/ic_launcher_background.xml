<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base dark background -->
    <path
        android:fillColor="#0D0B1F"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Deep radial gradient glow -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="80"
                android:startColor="#0D0B1F"
                android:endColor="#05030F" />
        </aapt:attr>
    </path>

    <!-- Subtle secondary gradient (adds richness) -->
    <path android:pathData="M0,0h108v108h-108z"
        android:fillAlpha="0.25">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:startColor="#0D0B1F"
                android:endColor="#000000" />
        </aapt:attr>
    </path>

    <!-- Diagonal light overlay -->
    <path
        android:fillAlpha="0.15"
        android:fillColor="#2A2356"
        android:pathData="M0,0 L108,108 L108,0 Z" />

</vector>